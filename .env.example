APP_ENV=dev
APP_NAME=lyra-chat-router-api
PUBLIC_BASE_URL=https://api.grupooliveirarocha.com/googlechat
DATABASE_URL=postgresql+psycopg://chat_router:CHANGE_ME@10.0.0.2:5432/lyra_chat_router
GOOGLE_CHAT_AUDIENCE=https://api.grupooliveirarocha.com/googlechat/
GOOGLE_CHAT_AUTH_MODE=app_url
GOOGLE_CHAT_DEV_BYPASS_AUTH=true
OPENCLAW_FORWARD_ENABLED=false
OPENCLAW_FORWARD_URL=
OPENCLAW_FORWARD_TIMEOUT_SECONDS=25
# Required in prod. Dev fallback is "dev-admin-secret" when unset.
MC_ADMIN_SHARED_SECRET=CHANGE_ME

# Google Workspace Events API / PubSub push endpoint
GOOGLE_CHAT_PUBSUB_SHARED_SECRET=replace-with-random-secret
GOOGLE_CHAT_BOT_USER=users/116909194009978426726
OPENCLAW_AGENT_HOOK_ENABLED=false
OPENCLAW_AGENT_HOOK_URL=http://100.114.82.11:18789/hooks/agent
OPENCLAW_AGENT_HOOK_TOKEN=replace-with-openclaw-hooks-token
OPENCLAW_AGENT_HOOK_AGENT_ID=main
OPENCLAW_AGENT_HOOK_TIMEOUT_SECONDS=120
OPENCLAW_AGENT_HOOK_REQUEST_TIMEOUT_SECONDS=10
